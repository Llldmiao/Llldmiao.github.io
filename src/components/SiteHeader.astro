---
interface Props {
  variant?: "default" | "article";
}

const { variant = "default" } = Astro.props;
---

<header class:list={["site-header", variant === "article" && "site-header-article"]} aria-label="站点导航">
  <a class="brand" href="/" aria-label="回到首页">
    <span class="brand-mark">Lm</span>
    <span class="brand-text">Llldmiao</span>
  </a>
  <nav class="nav-links" aria-label="主导航">
    <a href="/#work">方向</a>
    <a href="/#projects">项目</a>
    <a href="/notes/">笔记</a>
    <a href="/#contact">联系</a>
  </nav>
  <button class="theme-toggle" type="button" aria-label="切换明暗主题" data-theme-toggle>
    <span data-theme-icon>Dark</span>
  </button>
</header>
