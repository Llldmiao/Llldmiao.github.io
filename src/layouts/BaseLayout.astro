---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Llldmiao | Personal Site",
  description = "Llldmiao 的个人网站：AI 工具、市场数据、浏览器效率、技术笔记与项目作品。"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://llldmiao.github.io");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    <slot />
    <script src="/scripts/site.js" is:inline></script>
  </body>
</html>
